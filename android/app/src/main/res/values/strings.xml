    <!-- Welcome Screen (zero-knowledge) -->
    <string name="welcome_tagline">Co-parenting made simple</string>
    <string name="welcome_description">Securely share calendars, expenses, and schedules with your co-parent. End-to-end encrypted for your family\'s privacy.</string>
    <string name="welcome_set_up_new">Set Up New Device</string>
    <string name="welcome_restore">Restore from Recovery Phrase</string>
    <string name="welcome_zk_explanation">Your device key is your identity. No email or password needed. All data is end-to-end encrypted -- the server never sees your information.</string>

