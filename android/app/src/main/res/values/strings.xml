    <!-- Recovery Key Screen -->
    <string name="recovery_title">Recovery Key</string>
    <string name="recovery_heading">Save Your Recovery Phrase</string>
    <string name="recovery_description">Write down these 24 words in order. They are the only way to recover your data if you lose access to all your devices.</string>
    <string name="recovery_warning">If you lose these words and all your devices, your encrypted data cannot be recovered. Store them somewhere safe and offline.</string>
    <string name="recovery_saved_checkbox">I have written down and securely stored these words</string>
    <string name="recovery_continue">Continue</string>
    <string name="recovery_generating">Generating recovery phrase\u2026</string>
