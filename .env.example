# ============================================================
# KidSync Server Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
#
# IMPORTANT: Never commit the .env file to version control.
# ============================================================

# --- Data Paths (inside the container) -----------------------
# These map to the ./data volume mount in docker-compose.yml.
# You should not need to change these unless you change the
# volume mount path.
KIDSYNC_DB_PATH=/app/data/kidsync.db
KIDSYNC_BLOB_PATH=/app/data/blobs
KIDSYNC_SNAPSHOT_PATH=/app/data/snapshots

# --- Server ---------------------------------------------------
KIDSYNC_HOST=0.0.0.0
KIDSYNC_PORT=8080

# --- Authentication -------------------------------------------
# Session TTL in seconds (default: 3600 = 1 hour).
# KIDSYNC_SESSION_TTL_SECONDS=3600

# Challenge TTL in seconds for challenge-response auth (default: 60).
# KIDSYNC_CHALLENGE_TTL_SECONDS=60

# --- Server Origin --------------------------------------------
# The canonical origin URL for challenge-response authentication.
# MUST be set in production to the actual server URL.
# KIDSYNC_SERVER_ORIGIN=https://api.kidsync.app

# --- CORS -----------------------------------------------------
# Comma-separated list of allowed origins (hostnames without scheme).
# Leave unset for development (allows all origins).
# Set to your domain(s) in production, e.g.: app.kidsync.dev,kidsync.dev
# KIDSYNC_CORS_ORIGINS=app.kidsync.dev
