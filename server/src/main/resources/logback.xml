<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>requestId</includeMdcKeyName>
        </encoder>
    </appender>

    <appender name="STDOUT_TEXT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT_TEXT" />
    </root>

    <logger name="io.ktor" level="INFO" />
    <!-- SEC3-S-21: SECURITY WARNING - Setting Exposed to DEBUG will log full SQL statements
         including parameter values, which may contain session tokens, encrypted payloads,
         signing keys, and other sensitive data. NEVER set to DEBUG in production. -->
    <logger name="org.jetbrains.exposed" level="INFO" />
    <!-- SEC2-S-21: Default to INFO in production. Override via KIDSYNC_LOG_LEVEL env var
         or -Dlogback.configurationFile=/path/to/custom-logback.xml for DEBUG in development. -->
    <logger name="dev.kidsync" level="${KIDSYNC_LOG_LEVEL:-INFO}" />
</configuration>
