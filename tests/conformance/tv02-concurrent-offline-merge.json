    "winner": "Device B (bbbb1111-2222-3333-4444-555566667777)",
    "loser": "Device A (aaaa1111-2222-3333-4444-555566667777)",
    "loserDisposition": "Stored but marked as SUPERSEDED; not the active schedule"
