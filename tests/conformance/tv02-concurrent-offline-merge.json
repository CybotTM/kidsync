  "id": "TV02",
  "title": "Concurrent Offline Merge",
  "description": "Two devices (device-A, device-B) each create a custody schedule offline then sync. Both target the same child with the SAME effectiveFrom. Device B has a LATER clientTimestamp and therefore wins the tie-break per the conflict resolution rules in sync-protocol.md Section 12. In v2, all metadata (entityType, entityId, operation, clientTimestamp, deviceSequence) is inside the encrypted payload; the server sees only deviceId, keyEpoch, encryptedPayload, prevHash, currentHash.",
  "protocolVersion": 2,
  "specReferences": [
    "sync-protocol.md Section 11 (Canonical Linearization)",
    "sync-protocol.md Section 12 (Client-Side Conflict Resolution)",
    "wire-format.md Section 3.7 (Canonical Serialization for Encryption)",
    "wire-format.md Section 6 (DecryptedPayload)"
  ],
  "context": {
    "bucketId": "bkt00002-aaaa-bbbb-cccc-dddddddddddd",
    "childId": "c1d2e3f4-5678-9abc-def0-123456789012",
    "parentA": {
      "signingKeyFingerprint": "SHA256:parentA-signing-key-fingerprint-placeholder",
      "name": "Parent A (Alice)"
    },
    "parentB": {
      "signingKeyFingerprint": "SHA256:parentB-signing-key-fingerprint-placeholder",
      "name": "Parent B (Bob)"
    },
    "deviceA": {
      "deviceId": "aaaaaaaa-1111-2222-3333-444444444444",
      "name": "Alice's Phone"
    },
    "deviceB": {
      "deviceId": "bbbbbbbb-1111-2222-3333-444444444444",
      "name": "Bob's Phone"
    },
    "keyEpoch": 1
