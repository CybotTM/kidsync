  "conflictResolution": {
    "entityType": "CustodySchedule",
    "childId": "c1d2e3f4-5678-9abc-def0-123456789012",
    "strategy": "Latest effectiveFrom wins; tie-break by clientTimestamp; second tie-break by deviceId",
    "performedBy": "CLIENT (not server - server has no visibility into entityType or payload content)",
    "step1": {
      "comparison": "effectiveFrom",
      "deviceAValue": "2026-04-01T00:00:00.000Z",
      "deviceBValue": "2026-04-01T00:00:00.000Z",
      "result": "TIE - same effectiveFrom"
