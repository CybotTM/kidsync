  "scenario": {
    "step1": "Both devices go offline.",
    "step2": "Device A creates a custody schedule at clientTimestamp 2026-03-28T10:00:00.000Z.",
    "step3": "Device B creates a custody schedule at clientTimestamp 2026-03-28T10:05:00.000Z (5 minutes later).",
    "step4": "Both schedules have identical effectiveFrom: 2026-04-01T00:00:00.000Z.",
    "step5": "Device A comes online first and uploads. Server assigns globalSequence=1.",
    "step6": "Device B comes online second and uploads. Server assigns globalSequence=2.",
    "step7": "Both devices pull and apply conflict resolution. Conflict resolution is client-side only."
  },
