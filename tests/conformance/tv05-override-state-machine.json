        "CANCELLED": "INVALID (cannot cancel after approval)",
        "SUPERSEDED": "VALID (system only)",
        "EXPIRED": "VALID (system only)"
      },
      "DECLINED": {
        "PROPOSED": "INVALID (terminal state)",
        "APPROVED": "INVALID (terminal state)",
        "DECLINED": "INVALID (terminal state)",
        "CANCELLED": "INVALID (terminal state)",
        "SUPERSEDED": "INVALID (terminal state)",
