        "data": {
          "newEpoch": 2,
          "revokedDeviceId": "aa222222-3333-4444-5555-666666666666"
        }
      }
    },
    "wrappedDekRecipients": [
      {
        "deviceId": "aa111111-2222-3333-4444-555555555555",
        "description": "Alice's Phone - receives new wrapped DEK via POST /keys/wrapped"
