    "previousEpoch": 1,
    "newEpoch": 2,
    "newDekPlaceholder": "epoch-2-dek-256-bit-key-placeholder-00",
    "revocationOp": {
      "description": "In v2, device revocation is recorded as an encrypted op. The revoking device creates a DeviceRevocation op inside the encrypted payload.",
      "decryptedPayload": {
        "deviceSequence": 3,
        "entityType": "DeviceRevocation",
        "entityId": "aa222222-3333-4444-5555-666666666666",
        "operation": "CREATE",
        "clientTimestamp": "2026-03-20T12:00:00.000Z",
        "protocolVersion": 2,
        "data": {
          "revokedDeviceId": "aa222222-3333-4444-5555-666666666666",
          "reason": "ADMIN_REVOKE"
        }
      }
    },
    "keyRotationOp": {
      "description": "After revocation, the revoking device creates a KeyRotation op to signal the new epoch.",
      "decryptedPayload": {
        "deviceSequence": 4,
        "entityType": "KeyRotation",
        "entityId": "keyrot01-aaaa-bbbb-cccc-dddddddddddd",
        "operation": "CREATE",
