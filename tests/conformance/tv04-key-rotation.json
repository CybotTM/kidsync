  "rotationEvent": {
    "trigger": "Device revocation of Alice's Tablet (aa222222-3333-4444-5555-666666666666)",
    "revokedAt": "2026-03-20T12:00:00.000Z",
    "revokedDeviceId": "aa222222-3333-4444-5555-666666666666",
