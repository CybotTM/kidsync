{
  "id": "TV04",
  "title": "Key Rotation Scenario",
  "description": "Key rotation scenario triggered by device revocation. Epoch 1 has 3 ops, a device is revoked triggering DEK rotation to epoch 2, then 2 more ops are created with epoch 2. Verifies that each op carries the correct keyEpoch and that ops from both epochs are decryptable with their respective DEK. In v2, device revocation is a client-side concept: the revoking device creates a DeviceRevocation op inside the encrypted payload. Self-revoke only at the server level (DELETE /buckets/{id}/devices/me).",
  "protocolVersion": 2,
  "specReferences": [
    "encryption-spec.md Section 9 (Key Epochs)",
    "encryption-spec.md Section 10 (DEK Wrapping Protocol)",
    "encryption-spec.md Section 13 (OpLog Encryption and Decryption)",
    "sync-protocol.md Section 8 (WebSocket Protocol)",
    "wire-format.md Section 6 (DecryptedPayload)",
    "wire-format.md Section 7.7 (DeviceRevocation Data)",
    "wire-format.md Section 7.8 (KeyRotation Data)"
  ],
