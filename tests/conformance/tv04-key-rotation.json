        "note": "Active devices retain both epoch 1 (for historical decryption) and epoch 2 (for new ops)"
      },
      "revokedDevice": {
        "epochs": [1],
        "note": "Revoked device retains epoch 1 only; it never received epoch 2's wrapped DEK"
      }
    },
    "revokedDeviceExperience": {
      "existingOps": "Can still read ops 1-3 (encrypted with epoch 1 DEK which it already has locally)",
      "newOps": "Cannot decrypt ops 4-5 (encrypted with epoch 2 DEK which it never received)",
