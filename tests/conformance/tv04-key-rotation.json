    },
    "serverSideEffect": {
      "description": "The revoked device calls DELETE /buckets/{id}/devices/me to self-revoke at the server level. The server removes the device's session tokens and bucket membership. The server does NOT know why the device left (it only sees the self-revoke API call)."
    }
